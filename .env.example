# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Upstash Redis (from Upstash Console)
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Discord Channel IDs (comma-separated if multiple)
# You can set different channels for different topics
CHANNEL_AI=your_ai_channel_id
CHANNEL_LLM=your_llm_channel_id
CHANNEL_TECH=your_tech_channel_id
CHANNEL_OPENSOURCE=your_opensource_channel_id

# Or use a single channel for all news
CHANNEL_ALL=your_general_news_channel_id

# Cron schedule for fetching news (default: every 2 hours)
CRON_SCHEDULE=0 */2 * * *
